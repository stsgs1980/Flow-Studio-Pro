// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  flows     Flow[]
}

model Flow {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String?
  nodes       String   @default("[]")  // JSON stringified array of nodes
  edges       String   @default("[]")  // JSON stringified array of edges
  variables   String   @default("{}")  // JSON stringified object
  version     Int      @default(1)
  isPublic    Boolean  @default(false)
  isTemplate  Boolean  @default(false)
  thumbnail   String?  // Base64 encoded screenshot
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions  FlowExecution[]
}

model FlowExecution {
  id          String          @id @default(cuid())
  flowId      String
  status      ExecutionStatus @default(PENDING)
  input       String          @default("{}")   // JSON stringified input
  output      String?         // JSON stringified output
  nodeResults String          @default("{}")   // JSON stringified results per node
  error       String?
  startedAt   DateTime        @default(now())
  completedAt DateTime?
  duration    Int?            // Duration in milliseconds
  tokensUsed  Int?
  
  flow        Flow            @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// Node Templates - built-in and custom node definitions
model NodeTemplate {
  id          String   @id @default(cuid())
  type        String   @unique  // "llm", "agent", "tool", "input", "output", etc.
  name        String
  description String?
  category    String   // "input", "processing", "agent", "tool", "output", "logic", "memory", "utility", "data"
  configSchema String  @default("{}")  // JSON Schema for node configuration
  icon        String?
  color       String?  // Node color theme
  isBuiltIn   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// Prompt Templates
model PromptTemplate {
  id          String   @id @default(cuid())
  name        String
  acronym     String   @unique  // "RTF", "TAG", "BAB", etc.
  description String?
  sections    String            // JSON stringified array of sections
  useCase     String?
  isBuiltIn   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// User sessions and state
model UserSession {
  id          String   @id @default(cuid())
  userId      String?
  flowId      String?
  state       String   @default("{}")  // JSON stringified state
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime?
}
